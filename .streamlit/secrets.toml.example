# Copy this file to .streamlit/secrets.toml for local testing.
# On Streamlit Cloud, paste the same values into App settings -> Secrets.
# Never commit the real .streamlit/secrets.toml file.

SCAN_DB_BACKEND = "sqlite"

# Switch to "supabase" after running scripts/supabase_schema.sql in Supabase.
# SCAN_DB_BACKEND = "supabase"

SUPABASE_URL = "https://YOUR-PROJECT.supabase.co"

# Recommended for this prototype because full message text is private and should
# not be directly readable through a public anon key.
SUPABASE_SERVICE_ROLE_KEY = "paste-service-role-key-here"

# Optional alternative only if you later configure safe Row Level Security
# policies yourself. Do not use this with public SELECT access to full messages.
# SUPABASE_ANON_KEY = "paste-anon-key-here"
